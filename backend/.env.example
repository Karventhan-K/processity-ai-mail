# Port configuration (Optional)
PORT=3001

# Gemini API Key (Required for full LLM intelligence; falls back to offline rule-engine if empty)
GEMINI_API_KEY=

# Real SMTP / IMAP Configuration (Optional; falls back to Mock mode if empty)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# Optional Host & Port overrides (Auto-detected for Gmail/Outlook if empty)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
