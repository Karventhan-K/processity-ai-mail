# Ignore local dependency directories
node_modules/
**/node_modules/

# Ignore Next.js build output
.next/
**/ .next/
out/
**/out/

# Ignore Python virtual environments and caches
venv/
.venv/
**/venv/
**/ .venv/
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore local databases and environment configs
*.db
backend/processity.db
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Ignore Git and GitHub workflows
.git/
.github/
.gitignore
