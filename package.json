{
  "name": "processity-mail-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "npm install --legacy-peer-deps && python -m venv venv && .\\venv\\Scripts\\pip install -r backend/requirements.txt",
    "dev:backend": ".\\venv\\Scripts\\uvicorn backend.main:app --reload --port 8000",
    "dev:frontend": ".\\node_modules\\.bin\\next dev frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "dependencies": {
    "next": "15.1.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "lucide-react": "^0.469.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
